<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Test Suite" parallel="tests" thread-count="2">
    <listeners>
        <listener class-name="core.TestListener"/>
    </listeners>

    <!-- E2E UI Test -->
    <test name="Auth Tests">
        <classes>
            <class name="test.e2e.auth.LoginTest"/>
        </classes>
    </test>

    <test name="Dashboard Tests">
        <classes>
            <class name="test.e2e.dashboard.CompanyProfileTest"/>
            <class name="test.e2e.dashboard.FastTrackClassTest"/>
        </classes>
    </test>

    <test name="Class Management Tests">
        <classes>
            <class name="test.e2e.classmanagement.ViewClassTest"/>
            <class name="test.e2e.classmanagement.SearchClassTest"/>
        </classes>
    </test>

    <!-- Integration API Test -->
    <test name="API Integration Test : Auth Module">
        <classes>
            <class name="test.integration.auth.MutationLogin"/>
            <class name="test.integration.auth.MutationLogout"/>
        </classes>
    </test>

    <test name="API Integration Test : Dashboard Module">
        <classes>
            <class name="test.integration.dashboard.QueryMyCompany"/>
            <class name="test.integration.dashboard.QueryCountEmployees"/>
            <class name="test.integration.dashboard.QueryCountPrograms"/>
            <class name="test.integration.dashboard.QueryCountActiveTraining"/>
            <class name="test.integration.dashboard.QueryCountFinishTraining"/>
        </classes>
    </test>
</suite>